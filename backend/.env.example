# Copy this to .env for local development. On Render, set these as
# environment variables in the dashboard instead (DATABASE_URL is
# auto-provided when you link a Render Postgres instance).

PORT=4000
NODE_ENV=development

# Local Postgres (ignored if DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gs_hotel

# Render provides this automatically when linked to a Postgres instance.
# DATABASE_URL=postgres://user:password@host:port/dbname

# Comma-separated list of frontend URLs allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
